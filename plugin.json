{
  "id": "vocals_highway",
  "name": "Karaoke Highway",
  "version": "0.2.0",
  "feedback_target": "0.3.0-alpha.1",
  "private": false,
  "type": "visualization",
  "script": "screen.js",
  "routes": "routes.py",
  "category": "practice",
  "description": "SingStar-style pitch-ribbon highway for Vocals arrangements.",
  "icon": "assets/thumb.svg",
  "standards": [
    "capability-pipelines.v1"
  ],
  "capabilities": {
    "visualization": {
      "roles": [
        "provider"
      ],
      "operations": [
        "renderer.create",
        "renderer.destroy"
      ],
      "emits": [
        "renderer-ready",
        "renderer-failed"
      ],
      "mode": "active",
      "safety": "safe",
      "settings": [
        {
          "key": "octaveIndependent",
          "label": "Octave-free pitch match",
          "type": "toggle",
          "default": false
        },
        {
          "key": "tolerance",
          "label": "Pitch tolerance (semitones)",
          "type": "range",
          "default": 1,
          "min": 0.5,
          "max": 2,
          "step": 0.25
        }
      ]
    }
  }
}
